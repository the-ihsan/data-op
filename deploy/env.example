# Copy to deploy/.env on the VPS and fill in secrets.
# Never commit deploy/.env.

APP_NAME=DataOp
APP_ENV=production
APP_DEBUG=false
APP_KEY=                          # generate: docker compose run --rm app ./main artisan key:generate --show
APP_URL=https://your-domain.example
APP_HOST=0.0.0.0
APP_PORT=3000

JWT_SECRET=                       # generate: docker compose run --rm app ./main artisan jwt:secret --show

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=db                        # Docker service name; use real host if external DB
DB_PORT=3306
DB_DATABASE=dataop                # created automatically by bundled MySQL
DB_USERNAME=root                  # bundled stack uses root
DB_PASSWORD=change-me-strong-password  # also sets MYSQL_ROOT_PASSWORD

SESSION_DRIVER=file
SESSION_LIFETIME=120
