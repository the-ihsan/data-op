# Copy to api/.env — used for local dev (`go run .`) and Docker production (`deploy/`).
# Never commit api/.env.
#
# Local dev: DB_HOST=127.0.0.1, APP_HOST=127.0.0.1, APP_DEBUG=true, APP_PORT=3001 (or any free port)
# Docker prod: set DB_PASSWORD + DB_DATABASE; compose overrides APP_HOST=0.0.0.0, APP_PORT=3000, DB_HOST=db
#   (host port still uses APP_PORT from this file, e.g. 3001:3000)

APP_NAME=DataOp
APP_ENV=local
APP_KEY=
APP_DEBUG=true

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=file
SESSION_LIFETIME=120

APP_URL=http://localhost:3000
APP_HOST=127.0.0.1
APP_PORT=3000

JWT_SECRET=
# Token lifetime in minutes (12h); expired tokens can still be exchanged via
# POST /auth/refresh within JWT_REFRESH_TTL (default 2 weeks).
JWT_TTL=720

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=root
DB_PASSWORD=

GRPC_HOST=
GRPC_PORT=

MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=
